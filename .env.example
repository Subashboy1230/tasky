# ─── Butterbase (mandatory) ──────────────────────────────
# From dashboard.butterbase.ai
BUTTERBASE_URL=https://api.butterbase.ai
BUTTERBASE_API_KEY=
BUTTERBASE_PROJECT_ID=
# AI Gateway model preference — all LLM calls route through this
BUTTERBASE_LLM_MODEL=claude-opus-4-7

# ─── Neo4j (mandatory) ───────────────────────────────────
# From console.neo4j.io Aura instance
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ─── RocketRide Cloud (OPTIONAL, aspirational) ───────────
# Not currently wired. Leave blank — the judge falls back to Butterbase
# (which IS mandatory above). When RocketRide access is sorted, deploy
# the manifests in rocketride/pipelines/ and paste ids below.
ROCKETRIDE_API_URL=
ROCKETRIDE_API_KEY=
# The deployed pipeline IDs (populate after `rocketride deploy`).
# Prefer source-specific extract vars — gmail and granola have different
# prompts / schemas. The legacy ROCKETRIDE_PIPELINE_EXTRACT is a fallback
# for when only one is deployed.
ROCKETRIDE_PIPELINE_JUDGE=
ROCKETRIDE_PIPELINE_EXTRACT_GMAIL=
ROCKETRIDE_PIPELINE_EXTRACT_GRANOLA=
ROCKETRIDE_PIPELINE_EXTRACT=
ROCKETRIDE_PIPELINE_GRAPH_MERGE=
ROCKETRIDE_PIPELINE_BRIEF=

# ─── Composio (delegated OAuth) ──────────────────────────
# From app.composio.dev
COMPOSIO_API_KEY=
# Entity id — one per user; created on signup
COMPOSIO_ENTITY_ID=default

# ─── Granola (direct Bearer token, no OAuth) ─────────────
# Granola → Settings → Workspaces → API (Enterprise plan)
GRANOLA_API_KEY=

# ─── App ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to 'false' on Butterbase deployment if the judge misbehaves
TASKY_JUDGE_ENABLED=true

# ─── Optional bonus: Daytona ─────────────────────────────
DAYTONA_API_URL=
DAYTONA_API_KEY=

# ─── Cognee sidecar (OSS AI brain) ───────────────────────
# Points at the Python FastAPI wrapper in /cognee. Default is the
# docker-compose service on localhost. Leave the API_KEY blank —
# the sidecar isn't authenticated (localhost-only for the demo).
COGNEE_API_URL=http://localhost:8080
COGNEE_API_KEY=
#
# NO OpenAI key required. The compose file routes Cognee's LLM calls
# through Butterbase (above) and runs embeddings locally on CPU via
# fastembed. If you'd rather use OpenAI directly, set:
# OPENAI_API_KEY=sk-...
# and delete the LLM_* / EMBEDDING_* overrides in cognee/docker-compose.yml
